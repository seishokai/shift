 }
 
 // === Navigation ===
@@ -1379,3 +1380,232 @@ function renderReviews() {
     </tr>`;
   }).join('') || '<tr><td colspan="4" style="text-align:center;color:var(--text-muted)">データなし</td></tr>';
 }
+
+// ==================== 予約管理 ====================
+const RSV_SB_URL = 'https://trsugjpvhlkwjvtloype.supabase.co';
+const RSV_SB_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InRyc3VnanB2aGxrd2p2dGxveXBlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ4NTc4ODQsImV4cCI6MjA5MDQzMzg4NH0.GASbFeN_dLduCw81DQen8e4Hwc0TkHrcZWbB8dgNsec';
+const RSV_SB_H = {apikey:RSV_SB_KEY, Authorization:'Bearer '+RSV_SB_KEY, 'Content-Type':'application/json', Prefer:'return=representation'};
+
+let rsvData = [];
+let rsvFilter = 'all';
+
+function initReservations() {
+  document.getElementById('rsv-sync-btn').addEventListener('click', loadReservations);
+  document.getElementById('rsv-search').addEventListener('input', renderReservations);
+  document.querySelectorAll('[data-rsvf]').forEach(b => {
+    b.addEventListener('click', () => {
+      document.querySelectorAll('[data-rsvf]').forEach(x => x.classList.remove('active'));
+      b.classList.add('active');
+      rsvFilter = b.dataset.rsvf;
+      renderReservations();
+    });
+  });
+  loadReservations();
+}
+
+async function loadReservations() {
+  const listEl = document.getElementById('rsv-list');
+  listEl.innerHTML = '<p style="text-align:center;color:var(--muted);padding:40px 0">読み込み中...</p>';
+  try {
+    const r = await fetch(`${RSV_SB_URL}/rest/v1/reservations?select=*&order=appointment_date.desc`, {headers:RSV_SB_H});
+    if (!r.ok) throw new Error(r.statusText);
+    rsvData = await r.json();
+    renderRsvStats();
+    renderReservations();
+  } catch(e) {
+    listEl.innerHTML = `<p style="text-align:center;color:var(--red);padding:40px 0">読み込み失敗: ${e.message}<br><small>Supabaseにreservationsテーブルを作成してください</small></p>`;
+  }
+}
+
+function rsvFiltered() {
+  const q = (document.getElementById('rsv-search').value || '').toLowerCase();
+  return rsvData.filter(d => {
+    if (rsvFilter === 'new' && (d.visited || d.pre_cancel === 'キャンセル済')) return false;
+    if (rsvFilter === 'visited' && d.visited !== '来院済') return false;
+    if (rsvFilter === 'cancelled' && d.pre_cancel !== 'キャンセル済' && d.visited !== 'キャンセル') return false;
+    if (rsvFilter === 'contracted' && d.contracted !== '成約') return false;
+    if (rsvFilter === 'pending' && d.contracted !== '検討中') return false;
+    if (q) {
+      const t = [d.name, d.treatment, d.clinic, d.email, d.phone].join(' ').toLowerCase();
+      if (!t.includes(q)) return false;
+    }
+    return true;
+  });
+}
+
+function renderRsvStats() {
+  const total = rsvData.length;
+  const visited = rsvData.filter(d => d.visited === '来院済').length;
+  const cancel = rsvData.filter(d => d.pre_cancel === 'キャンセル済' || d.visited === 'キャンセル').length;
+  const contract = rsvData.filter(d => d.contracted === '成約').length;
+  const amount = rsvData.reduce((s, d) => s + (d.contract_amount || 0), 0);
+  const amountStr = amount > 0 ? (amount >= 10000 ? Math.round(amount / 10000) + '万' : amount.toLocaleString()) : '-';
+
+  document.getElementById('rsv-stats').innerHTML = `
+    <div class="stat-card"><span class="stat-num">${total}</span><span class="stat-label">総予約</span></div>
+    <div class="stat-card"><span class="stat-num" style="color:var(--green)">${visited}</span><span class="stat-label">来院済</span></div>
+    <div class="stat-card"><span class="stat-num" style="color:var(--red)">${cancel}</span><span class="stat-label">ｷｬﾝｾﾙ</span></div>
+    <div class="stat-card"><span class="stat-num" style="color:#7030a0">${contract}</span><span class="stat-label">成約</span></div>
+    <div class="stat-card"><span class="stat-num" style="color:#7030a0;font-size:16px">¥${amountStr}</span><span class="stat-label">売上</span></div>
+  `;
+  document.getElementById('rsv-count').textContent = `${rsvFiltered().length}/${total}件`;
+}
+
+const RSV_CLINIC_COLORS = {
+  'BF銀座歯科':'#7d6608','エスカ':'#c0392b','アール':'#7030a0','ウィズ':'#1e8449',
+  'ルミナス':'#27ae60','名古屋ルミナス':'#27ae60','茶屋':'#d4a017','アサノ':'#85200c',
+  '知立':'#0a6b8a','小牧':'#d81b60','八事':'#8b4513','大森':'#1f6b4e','京都':'#6b3a87',
+  '銀座':'#7d6608','訪問':'#2c6e8a',
+};
+function rsvClinicColor(c) {
+  if (!c) return {bg:'#f2f2f0',fg:'#999'};
+  for (const [k,v] of Object.entries(RSV_CLINIC_COLORS)) { if (c.includes(k)) return {bg:v+'18',fg:v}; }
+  return {bg:'#e8f4fd',fg:'#2d6a9f'};
+}
+
+function rsvFormatDate(s) {
+  if (!s) return '-';
+  const d = new Date(s);
+  if (isNaN(d)) return s;
+  const dow = ['日','月','火','水','木','金','土'][d.getDay()];
+  return `${d.getMonth()+1}/${d.getDate()}(${dow}) ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
+}
+function rsvFormatDateShort(s) {
+  if (!s) return '-';
+  const d = new Date(s);
+  if (isNaN(d)) return s;
+  return `${d.getMonth()+1}/${d.getDate()}`;
+}
+function rsvEsc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
+
+function renderReservations() {
+  const list = rsvFiltered();
+  const el = document.getElementById('rsv-list');
+  document.getElementById('rsv-count').textContent = `${list.length}/${rsvData.length}件`;
+
+  if (!list.length) {
+    el.innerHTML = '<p style="text-align:center;color:var(--muted);padding:40px 0">該当する予約がありません</p>';
+    return;
+  }
+
+  el.innerHTML = list.map(d => {
+    const cc = rsvClinicColor(d.clinic);
+    const isCancelled = d.pre_cancel === 'キャンセル済' || d.visited === 'キャンセル';
+    let badges = '';
+    if (d.pre_cancel === 'キャンセル済') badges += '<span class="rsv-badge rsv-badge-cancel">事前ｷｬﾝｾﾙ</span>';
+    if (d.visited === '来院済') badges += '<span class="rsv-badge rsv-badge-visited">来院済</span>';
+    else if (d.visited === 'キャンセル') badges += '<span class="rsv-badge rsv-badge-cancel">当日ｷｬﾝｾﾙ</span>';
+    else if (d.pre_cancel !== 'キャンセル済') badges += '<span class="rsv-badge rsv-badge-default">未来院</span>';
+    if (d.contracted === '成約') badges += '<span class="rsv-badge rsv-badge-contract">成約</span>';
+    else if (d.contracted === '検討中') badges += '<span class="rsv-badge rsv-badge-pending">検討中</span>';
+    else if (d.contracted === '未成約') badges += '<span class="rsv-badge rsv-badge-nocontract">未成約</span>';
+
+    return `<div class="rsv-card${isCancelled?' rsv-cancelled':''}" onclick="openRsvModal('${d.id}')">
+      <div class="rsv-card-top">
+        <div>
+          <span class="rsv-card-name">${rsvEsc(d.name||'名前なし')}</span>
+          <span class="rsv-card-clinic" style="background:${cc.bg};color:${cc.fg}">${rsvEsc(d.clinic||'-')}</span>
+        </div>
+        <div style="text-align:right">
+          <div class="rsv-card-date">${rsvFormatDate(d.appointment_date)}</div>
+          <div style="font-size:10px;color:var(--text-muted)">登録 ${rsvFormatDateShort(d.registration_date)}</div>
+        </div>
+      </div>
+      <div class="rsv-card-treatment">${rsvEsc(d.treatment||'-')}</div>
+      ${d.promotion?'<div class="rsv-card-promo">'+rsvEsc(d.promotion)+'</div>':''}
+      <div class="rsv-badges">${badges}</div>
+      ${d.contract_amount?'<div class="rsv-card-amount">¥'+Number(d.contract_amount).toLocaleString()+'</div>':''}
+    </div>`;
+  }).join('');
+}
+
+function openRsvModal(id) {
+  const d = rsvData.find(x => x.id === id);
+  if (!d) return;
+  const cc = rsvClinicColor(d.clinic);
+  const m = document.getElementById('rsv-modal-body');
+  m.innerHTML = `
+    <button class="modal-close" onclick="document.getElementById('rsv-modal').hidden=true">&times;</button>
+    <h3 style="font-size:18px;margin-bottom:16px">${rsvEsc(d.name||'名前なし')}</h3>
+    <div class="rsv-modal-info"><b>予約日時:</b> ${rsvFormatDate(d.appointment_date)}</div>
+    <div class="rsv-modal-info"><b>登録日:</b> ${rsvFormatDateShort(d.registration_date)}</div>
+    <div class="rsv-modal-info"><b>施術:</b> ${rsvEsc(d.treatment||'-')}</div>
+    <div class="rsv-modal-info"><b>クリニック:</b> <span style="background:${cc.bg};color:${cc.fg};padding:1px 6px;border-radius:4px;font-weight:600">${rsvEsc(d.clinic||'-')}</span></div>
+    <div class="rsv-modal-info"><b>連絡先:</b> <a href="tel:${d.phone||''}" style="color:var(--primary)">${rsvEsc(d.phone||'-')}</a></div>
+    <div class="rsv-modal-info"><b>メール:</b> <a href="mailto:${d.email||''}" style="color:var(--primary);font-size:11px">${rsvEsc(d.email||'-')}</a></div>
+    ${d.promotion?'<div class="rsv-modal-info"><b>プロモーション:</b> '+rsvEsc(d.promotion)+'</div>':''}
+
+    <div class="rsv-modal-section">
+      <h4>事前キャンセル</h4>
+      <div class="rsv-modal-btns">
+        <button class="rsv-mbtn ${d.pre_cancel==='キャンセル済'?'rsv-mbtn-cancel':''}" onclick="rsvSetField('${id}','pre_cancel','キャンセル済')">キャンセル済</button>
+        <button class="rsv-mbtn ${!d.pre_cancel||d.pre_cancel===''?'rsv-mbtn-active':''}" onclick="rsvSetField('${id}','pre_cancel','')">なし</button>
+      </div>
+    </div>
+
+    <div class="rsv-modal-section">
+      <h4>来院状況</h4>
+      <div class="rsv-modal-btns">
+        <button class="rsv-mbtn ${d.visited==='来院済'?'rsv-mbtn-visited':''}" onclick="rsvSetField('${id}','visited','来院済')">来院済</button>
+        <button class="rsv-mbtn ${d.visited==='キャンセル'?'rsv-mbtn-cancel':''}" onclick="rsvSetField('${id}','visited','キャンセル')">キャンセル</button>
+        <button class="rsv-mbtn ${!d.visited||d.visited===''?'rsv-mbtn-active':''}" onclick="rsvSetField('${id}','visited','')">未来院</button>
+      </div>
+    </div>
+
+    <div class="rsv-modal-section">
+      <h4>成約状況</h4>
+      <div class="rsv-modal-btns">
+        <button class="rsv-mbtn ${d.contracted==='成約'?'rsv-mbtn-contract':''}" onclick="rsvSetField('${id}','contracted','成約')">成約</button>
+        <button class="rsv-mbtn ${d.contracted==='検討中'?'rsv-mbtn-pending':''}" onclick="rsvSetField('${id}','contracted','検討中')">検討中</button>
+        <button class="rsv-mbtn ${d.contracted==='未成約'?'rsv-mbtn-nocontract':''}" onclick="rsvSetField('${id}','contracted','未成約')">未成約</button>
+      </div>
+    </div>
+
+    <div class="rsv-modal-section">
+      <h4>成約金額</h4>
+      <div style="display:flex;gap:8px;align-items:center;margin-top:8px">
+        <input type="number" class="form-input" id="rsv-amount-input" value="${d.contract_amount||''}" placeholder="0" style="flex:1;text-align:right;font-size:16px" inputmode="numeric">
+        <span style="font-weight:600;color:var(--text-muted)">円</span>
+      </div>
+      <button class="btn btn-dark" style="width:100%;margin-top:10px;background:#7030a0;border-color:#7030a0" onclick="rsvSaveAmount('${id}')">金額を保存</button>
+    </div>
+
+    <button class="btn" style="width:100%;margin-top:12px" onclick="document.getElementById('rsv-modal').hidden=true">閉じる</button>
+  `;
+  document.getElementById('rsv-modal').hidden = false;
+}
+
+async function rsvSetField(id, field, value) {
+  try {
+    const body = {}; body[field] = value;
+    const r = await fetch(`${RSV_SB_URL}/rest/v1/reservations?id=eq.${id}`, {
+      method: 'PATCH', headers: RSV_SB_H, body: JSON.stringify(body)
+    });
+    if (!r.ok) throw new Error(r.statusText);
+    const updated = await r.json();
+    if (updated.length) { const idx = rsvData.findIndex(x => x.id === id); if (idx >= 0) rsvData[idx] = updated[0]; }
+    openRsvModal(id);
+    renderRsvStats();
+    renderReservations();
+  } catch(e) {
+    alert('更新失敗: ' + e.message);
+  }
+}
+
+async function rsvSaveAmount(id) {
+  const val = document.getElementById('rsv-amount-input').value;
+  const amount = val ? parseInt(val) : null;
+  try {
+    const r = await fetch(`${RSV_SB_URL}/rest/v1/reservations?id=eq.${id}`, {
+      method: 'PATCH', headers: RSV_SB_H, body: JSON.stringify({contract_amount: amount})
+    });
+    if (!r.ok) throw new Error(r.statusText);
+    const updated = await r.json();
+    if (updated.length) { const idx = rsvData.findIndex(x => x.id === id); if (idx >= 0) rsvData[idx] = updated[0]; }
+    renderRsvStats();
+    renderReservations();
+    alert('金額を保存しました');
+  } catch(e) {
+    alert('保存失敗: ' + e.message);
+  }
+}
